{
  "name": "@xds/docsite",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build:theme": "xds theme build src/themes/astryxTheme.ts --out src/themes/astryx.css",
    "generate": "pnpm build:theme && node scripts/generate-data.mjs && node scripts/generate-playground-types.mjs && node scripts/copy-vendor.mjs",
    "dev": "pnpm generate && next dev",
    "build": "pnpm generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@stylexjs/stylex": "^0.18.3",
    "@xds/cli": "*",
    "@xds/core": "*",
    "@xds/theme-butter": "*",
    "@xds/theme-default": "*",
    "@xds/theme-gothic": "*",
    "@xds/theme-matcha": "*",
    "@xds/theme-neutral": "*",
    "@xds/theme-stone": "*",
    "@xds/theme-y2k": "*",
    "@heroicons/react": "^2.2.0",
    "lucide-react": "^1.17.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.55.1",
    "next": "^15.5.16",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@stylexjs/babel-plugin": "^0.18.3",
    "@stylexjs/postcss-plugin": "^0.18.3",
    "@types/lz-string": "^1.5.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.1"
  },
  "browserslist": [
    "last 1 Chrome version"
  ]
}
